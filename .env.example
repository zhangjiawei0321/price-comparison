# 复制本文件为 .env 后生效（项目已用 dotenv 加载）。
# 给 Playwright 用的 Chrome 用户数据目录，用于保留京东/淘宝等登录态。
# 首次使用请在该目录下用 --headful 登录一次。

PRICE_USER_DATA_DIR=C:\Users\你的Windows用户名\price-monitor-profile

# 钉钉机器人配置
#钉钉创建群机器人，获取token和密钥
# 钉钉机器人勾选了「加签」时填写 SEC 开头密钥（与 ALERT_WEBHOOK_FORMAT=dingtalk 配合）
# DINGTALK_SECRET=SECXXX
#ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=XXXXXX
#ALERT_WEBHOOK_FORMAT=dingtalk


# 风控/验证码 webhook 同一商品最小间隔（秒），默认 3600；0=不限制
# RISK_WEBHOOK_COOLDOWN_SECONDS=3600
